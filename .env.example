# ============================================================
# CAROLIN CODE PRO AI — Environment Variables
# Copy this file to .env and fill in all values
# NEVER commit .env to git — it is in .gitignore
# ============================================================

# ── App ──────────────────────────────────────────────────────
APP_ENV=development
APP_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,https://carolincodepro.ai

# ── AWS Core ─────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# ── AWS Cognito ───────────────────────────────────────────────
# Create a User Pool in AWS Console before setting these
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=your_app_client_id_here
COGNITO_CLIENT_SECRET=your_app_client_secret_here

# ── JWT ───────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace_with_64_hex_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── PostgreSQL (AWS RDS) ──────────────────────────────────────
DATABASE_URL=postgresql://chcuser:yourpassword@your-rds-endpoint.rds.amazonaws.com:5432/chcprodb

# ── Redis (AWS ElastiCache or local) ─────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── NPPES NPI Registry (public, no key required) ─────────────
NPPES_API_BASE=https://npiregistry.cms.hhs.gov/api
NPPES_API_VERSION=2.1

# ── OIG LEIE Exclusion Database ──────────────────────────────
OIG_LEIE_API_BASE=https://oig.hhs.gov/exclusions/api/1.0/get-full-record

# ── CMS PECOS Medicare Enrollment ────────────────────────────
PECOS_API_BASE=https://data.cms.gov/provider-data/api/1/datastore/query/4j6d-yzce/0

# ── AWS SES (email OTP) ───────────────────────────────────────
# Must be in production mode (not sandbox) to send to any email
SES_FROM_EMAIL=noreply@carolincodepro.ai
SES_CONFIGURATION_SET=chc-transactional

# ── OTP Settings ─────────────────────────────────────────────
OTP_EXPIRE_SECONDS=300
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=3
OTP_RATE_WINDOW_SECONDS=600

# ── TOTP 2FA ─────────────────────────────────────────────────
TOTP_ISSUER=CarolinCodeProAI
TOTP_INTERVAL=30

# ── AWS S3 ───────────────────────────────────────────────────
# Layer 1 only needs the deidentified bucket for e-signatures
S3_BUCKET_RAW=chc-raw-uploads
S3_BUCKET_DEIDENTIFIED=chc-deidentified

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_OTP=3/minute
RATE_LIMIT_REGISTER=10/minute

# ── Sentry (error tracking, optional) ────────────────────────
SENTRY_DSN=
